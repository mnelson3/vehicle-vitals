#!/bin/bash
# 🚀 Vehicle Vitals - Master Automation Controller
# Unified interface for all DevOps operations
# CRITICAL: Bash 3.2 compatible - NO associative arrays

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Load configuration
if [ -f ".env.automation" ]; then
    source .env.automation
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Helper functions
log_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
log_success() { echo -e "${GREEN}✅ $1${NC}"; }
log_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
log_error() { echo -e "${RED}❌ $1${NC}"; }

log_header() {
    echo -e "${PURPLE}🚀 $1${NC}"
    echo -e "${PURPLE}$(printf '%.0s=' {1..50})${NC}"
}

# Check prerequisites
check_prerequisites() {
    local missing_tools=""

    # Check required tools
    command -v jq >/dev/null 2>&1 || missing_tools="$missing_tools jq"
    command -v docker >/dev/null 2>&1 || missing_tools="$missing_tools docker"
    command -v firebase >/dev/null 2>&1 || missing_tools="$missing_tools firebase"

    if [ -n "$missing_tools" ]; then
        log_error "Missing required tools:$missing_tools"
        log_info "Please install missing tools and try again"
        exit 1
    fi

    # Check GitHub CLI (optional but recommended)
    if ! command -v gh >/dev/null 2>&1; then
        log_warning "GitHub CLI not found - some features will be limited"
    fi
}

# Command dispatcher
main() {
    local command="$1"
    local subcommand="$2"
    local environment="${3:-development}"

    # Change to project root
    cd "$PROJECT_ROOT"

    # Check prerequisites for most commands
    case "$command" in
        "help"|"-h"|"--help") show_help; return ;;
        "version"|"-v"|"--version") show_version; return ;;
    esac

    check_prerequisites

    case "$command" in
        "setup")
            setup_system
            ;;
        "deploy")
            deploy_system "$subcommand" "$environment"
            ;;
        "monitor")
            manage_monitoring "$subcommand"
            ;;
        "tokens")
            manage_tokens "$subcommand"
            ;;
        "environment")
            manage_environment "$subcommand" "$environment"
            ;;
        "health")
            health_check
            ;;
        "docker")
            manage_docker "$subcommand"
            ;;
        "runners")
            manage_runners "$subcommand"
            ;;
        *)
            log_error "Unknown command: $command"
            show_help
            exit 1
            ;;
    esac
}

# Setup system
setup_system() {
    log_header "System Setup"

    # Create necessary directories
    mkdir -p scripts
    mkdir -p monitoring
    mkdir -p docker

    # Check if .env.automation exists
    if [ ! -f ".env.automation" ]; then
        log_warning ".env.automation not found. Creating from template..."
        create_env_template
        log_info "Please edit .env.automation with your actual credentials"
        log_info "Then run: ./automate.sh setup"
        exit 0
    fi

    # Setup environment management
    log_info "Setting up environment management..."
    bash scripts/manage-environments.sh setup development

    # Setup monitoring
    log_info "Setting up monitoring system..."
    bash scripts/monitoring.sh setup

    # Setup runners
    log_info "Setting up GitHub runners..."
    manage_runners setup

    log_success "System setup completed!"
    log_info "Run './automate.sh health' to verify everything is working"
}

# Deploy system
deploy_system() {
    local target="$1"
    local environment="$2"

    log_header "Deployment - $target to $environment"

    case "$target" in
        "web")
            deploy_web "$environment"
            ;;
        "mobile")
            deploy_mobile "$environment"
            ;;
        "full")
            deploy_full "$environment"
            ;;
        *)
            log_error "Unknown deployment target: $target"
            log_info "Available targets: web, mobile, full"
            exit 1
            ;;
    esac
}

# Deploy web application
deploy_web() {
    local environment="$1"
    log_info "Deploying web application to $environment..."

    # Validate environment
    validate_environment "$environment"

    # Get Firebase project ID (Bash 3.2 compatible)
    local firebase_project
    eval "firebase_project=\$ENV_CONFIGS_$environment"

    if [ -z "$firebase_project" ]; then
        log_error "Firebase project not configured for environment: $environment"
        exit 1
    fi

    # Build and deploy
    cd web
    npm run build
    firebase use "$firebase_project"
    firebase deploy --only hosting
    cd ..

    log_success "Web application deployed to $environment"
}

# Deploy mobile applications
deploy_mobile() {
    local environment="$1"
    log_info "Deploying mobile applications to $environment..."

    # This would integrate with fastlane or similar
    # For now, just build
    cd mobile
    flutter build apk --release
    flutter build ios --release
    cd ..

    log_success "Mobile applications built for $environment"
}

# Full deployment
deploy_full() {
    local environment="$1"
    log_info "Performing full deployment to $environment..."

    deploy_web "$environment"
    deploy_mobile "$environment"

    log_success "Full deployment completed for $environment"
}

# Manage monitoring
manage_monitoring() {
    local action="$1"

    case "$action" in
        "start")
            log_info "Starting monitoring system..."
            bash scripts/monitoring.sh &
            echo $! > monitoring/monitor.pid
            log_success "Monitoring started (PID: $(cat monitoring/monitor.pid))"
            ;;
        "stop")
            if [ -f "monitoring/monitor.pid" ]; then
                kill "$(cat monitoring/monitor.pid)" 2>/dev/null || true
                rm monitoring/monitor.pid
                log_success "Monitoring stopped"
            else
                log_warning "Monitoring not running"
            fi
            ;;
        "status")
            if [ -f "monitoring/monitor.pid" ] && kill -0 "$(cat monitoring/monitor.pid)" 2>/dev/null; then
                log_success "Monitoring is running (PID: $(cat monitoring/monitor.pid))"
            else
                log_info "Monitoring is not running"
            fi
            ;;
        "once")
            log_info "Running monitoring check..."
            bash scripts/monitoring.sh --once
            ;;
        *)
            log_error "Unknown monitoring action: $action"
            log_info "Available actions: start, stop, status, once"
            exit 1
            ;;
    esac
}

# Manage tokens
manage_tokens() {
    local action="$1"

    case "$action" in
        "rotate")
            log_info "Rotating tokens..."
            bash scripts/token-rotation.sh rotate
            ;;
        "status")
            log_info "Checking token status..."
            bash scripts/token-rotation.sh status
            ;;
        *)
            log_error "Unknown token action: $action"
            log_info "Available actions: rotate, status"
            exit 1
            ;;
    esac
}

# Manage environments
manage_environment() {
    local action="$1"
    local environment="$2"

    case "$action" in
        "setup")
            log_info "Setting up environment: $environment"
            bash scripts/manage-environments.sh setup "$environment"
            ;;
        "sync-secrets")
            log_info "Syncing secrets for environment: $environment"
            bash scripts/manage-environments.sh sync-secrets "$environment"
            ;;
        "status")
            log_info "Checking environment status: $environment"
            bash scripts/manage-environments.sh status "$environment"
            ;;
        *)
            log_error "Unknown environment action: $action"
            log_info "Available actions: setup, sync-secrets, status"
            exit 1
            ;;
    esac
}

# Health check
health_check() {
    log_header "System Health Check"

    local issues_found=0

    # Check configuration
    if [ ! -f ".env.automation" ]; then
        log_error "Configuration file missing: .env.automation"
        issues_found=$((issues_found + 1))
    else
        log_success "Configuration file found"
    fi

    # Check required scripts
    local required_scripts="manage-environments.sh monitoring.sh token-rotation.sh"
    for script in $required_scripts; do
        if [ ! -f "scripts/$script" ]; then
            log_error "Required script missing: scripts/$script"
            issues_found=$((issues_found + 1))
        else
            log_success "Script found: $script"
        fi
    done

    # Check GitHub CLI authentication
    if command -v gh >/dev/null 2>&1; then
        if gh auth status >/dev/null 2>&1; then
            log_success "GitHub CLI authenticated"
        else
            log_warning "GitHub CLI not authenticated"
        fi
    else
        log_warning "GitHub CLI not installed"
    fi

    # Check Docker
    if docker ps >/dev/null 2>&1; then
        log_success "Docker accessible"
    else
        log_error "Docker not accessible"
        issues_found=$((issues_found + 1))
    fi

    # Check Firebase
    if firebase projects:list >/dev/null 2>&1; then
        log_success "Firebase accessible"
    else
        log_warning "Firebase not accessible or not logged in"
    fi

    # Check runners
    manage_runners status >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        log_success "GitHub runners operational"
    else
        log_warning "GitHub runners may not be operational"
    fi

    # Summary
    if [ $issues_found -eq 0 ]; then
        log_success "All health checks passed!"
    else
        log_error "Found $issues_found health issues"
        exit 1
    fi
}

# Manage Docker operations
manage_docker() {
    local action="$1"

    case "$action" in
        "build")
            log_info "Building Docker images..."
            # Add Docker build commands here
            log_success "Docker images built"
            ;;
        "runner")
            manage_runners setup
            ;;
        *)
            log_error "Unknown Docker action: $action"
            log_info "Available actions: build, runner"
            exit 1
            ;;
    esac
}

# Manage GitHub runners
manage_runners() {
    local action="$1"

    case "$action" in
        "setup")
            log_info "Setting up GitHub runners..."

            # Linux runner (Docker)
            if [ -f "docker-compose.runner.yml" ]; then
                log_info "Starting Linux Docker runner..."
                docker compose --env-file .env.runner -f docker-compose.runner.yml up -d 2>/dev/null || true
            fi

            # macOS runner (if on macOS)
            if [ "$(uname)" = "Darwin" ] && [ -d "actions-runner" ]; then
                log_info "Setting up macOS runner..."
                cd actions-runner
                ./svc.sh install 2>/dev/null || true
                ./svc.sh start 2>/dev/null || true
                cd ..
            fi

            log_success "GitHub runners setup completed"
            ;;
        "status")
            local linux_status="unknown"
            local macos_status="unknown"

            # Check Linux runner
            if docker ps --filter "name=vehicle-vitals-runner" --format "{{.Names}}" | grep -q "vehicle-vitals-runner"; then
                linux_status="running"
            fi

            # Check macOS runner
            if [ "$(uname)" = "Darwin" ] && [ -d "actions-runner" ]; then
                if ./actions-runner/svc.sh status 2>/dev/null | grep -q "Started"; then
                    macos_status="running"
                fi
            fi

            echo "Linux Runner: $linux_status"
            echo "macOS Runner: $macos_status"

            if [ "$linux_status" = "running" ] || [ "$macos_status" = "running" ]; then
                return 0
            else
                return 1
            fi
            ;;
        *)
            log_error "Unknown runner action: $action"
            log_info "Available actions: setup, status"
            exit 1
            ;;
    esac
}

# Validate environment (Bash 3.2 compatible)
validate_environment() {
    local env="$1"
    case "$env" in
        development|staging|production) return 0 ;;
        *) log_error "Invalid environment: $env"; exit 1 ;;
    esac
}

# Create environment template
create_env_template() {
    cat > .env.automation << 'EOF'
# 🎯 Vehicle Vitals - Automation Configuration
# Copy this template and fill in actual values

# ==========================================
# ALERTING & NOTIFICATIONS
# ==========================================

# Email alerts (SMTP)
ALERT_EMAIL=your-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Slack notifications
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ==========================================
# MONITORING CONFIGURATION
# ==========================================

# Monitoring interval (seconds)
MONITOR_INTERVAL=300

# Health check files
LOG_FILE=automation.log
HEALTH_FILE=health-status.json

# ==========================================
# GITHUB CONFIGURATION
# ==========================================

# GitHub repository
GITHUB_REPO=mnelson3/vehicle-vitals
GITHUB_TOKEN=your-github-token

# ==========================================
# FIREBASE CONFIGURATION (Bash 3.2 compatible)
# ==========================================

# Environment-specific Firebase projects
ENV_CONFIGS_development=vehicle-vitals-dev
ENV_CONFIGS_staging=vehicle-vitals-staging
ENV_CONFIGS_production=vehicle-vitals-prod

# Firebase service account (JSON content)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ==========================================
# DEPLOYMENT TARGETS
# ==========================================

# Web app domains
WEB_DEV_DOMAIN=https://vehicle-vitals-dev.web.app
WEB_STAGING_DOMAIN=https://vehicle-vitals-staging.web.app
WEB_PROD_DOMAIN=https://vehicle-vitals-prod.web.app

# API endpoints
API_DEV_ENDPOINT=https://us-central1-vehicle-vitals-dev.cloudfunctions.net/api
API_STAGING_ENDPOINT=https://us-central1-vehicle-vitals-staging.cloudfunctions.net/api
API_PROD_ENDPOINT=https://us-central1-vehicle-vitals-prod.cloudfunctions.net/api

# ==========================================
# MOBILE APP CONFIGURATION
# ==========================================

# iOS App Store Connect
ASC_KEY_ID=your-asc-key-id
ASC_ISSUER_ID=your-asc-issuer-id
ASC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----
FASTLANE_APPLE_ID=your-apple-id@email.com
FASTLANE_TEAM_ID=your-team-id

# Android Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
ANDROID_KEYSTORE_PASSWORD=your-keystore-password

# ==========================================
# SECURITY & CERTIFICATES
# ==========================================

# JWT and encryption
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-encryption-key
SESSION_SECRET=your-session-secret

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

# Debug mode
DEBUG_MODE=false
VERBOSE_LOGGING=false

# Local development
LOCAL_API_PORT=5001
LOCAL_WEB_PORT=3000
EOF

    log_success "Created .env.automation template"
}

# Show help
show_help() {
    echo "🎯 Vehicle Vitals - Master Automation Controller"
    echo "Unified interface for all DevOps operations"
    echo ""
    echo "Usage: $0 <command> [subcommand] [environment]"
    echo ""
    echo "Commands:"
    echo "  setup                    Complete system setup"
    echo "  deploy     <target>      Deploy to target (web|mobile|full) [environment]"
    echo "  monitor    <action>      Monitoring (start|stop|status|once)"
    echo "  tokens     <action>      Token management (rotate|status)"
    echo "  environment <action>     Environment management (setup|sync|status) [environment]"
    echo "  health                   System health check"
    echo "  docker     <action>      Docker management (build|runner)"
    echo "  runners    <action>      GitHub runners (setup|status)"
    echo ""
    echo "Environments: development (default), staging, production"
    echo ""
    echo "Examples:"
    echo "  $0 setup"
    echo "  $0 deploy web production"
    echo "  $0 monitor start"
    echo "  $0 health"
    echo "  $0 environment setup development"
}

# Show version
show_version() {
    echo "Vehicle Vitals Automation Controller v1.0.0"
    echo "Bash 3.2 compatible"
}

# Run main function with all arguments
main "$@"</content>
