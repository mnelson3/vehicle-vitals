# Matchfile for code signing configuration
# This file configures how match handles certificates and provisioning profiles

# The Git URL to your private certificates repository
git_url(ENV["MATCH_GIT_URL"])

# The branch to use for match - dynamically set based on environment
# For production deployments, use 'main' branch certificates
# For staging/develop deployments, use 'develop' branch certificates
git_branch(ENV["MATCH_GIT_BRANCH"] || "develop")

# Storage mode (git, google_cloud, s3)
storage_mode("git")

# Type of match (development, adhoc, appstore, enterprise)
type("appstore")

# App Identifier for this app (if not specified in Appfile)
# app_identifier(["com.wishlistwizard.mobile"])

# Username for the Apple ID
username(ENV["FASTLANE_APPLE_ID"])

# Team ID
team_id(ENV["FASTLANE_TEAM_ID"])

# Keychain name (default: login.keychain)
# keychain_name("login.keychain")

# Keychain password (default: empty)
# keychain_password("")

# Force a specific device type for development certificates
# force_for_new_devices(false)

# Should match include the platform in the git branch
# platform("ios")

# Should match skip Google Cloud setup validation
# skip_google_cloud_account_confirmation(true)

# Should match skip provisioning profile validation
# skip_provisioning_profiles(true)

# Should match force a clean repo (default: false)
# force(false)

# Should match shallow clone the repo (default: false)
# shallow_clone(true)

# Should match clone the repo with a specific depth
# clone_depth(1)

# Should match use a specific git branch for each environment
# Separate branch for each environment
# type("development") { git_branch("certs-development") }
# type("adhoc") { git_branch("certs-adhoc") }
# type("appstore") { git_branch("certs-appstore") }

# NOTE: Encryption is not required. Unencrypted certificate and profile files are expected in the repo.
# When new certificates are needed, run match in non-readonly mode to generate and commit them.
# Example: fastlane match appstore --readonly false