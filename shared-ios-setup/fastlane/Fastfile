# Fastfile for Vehicle Vitals iOS build/release operations

default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV['CI']
  end

  desc "Load App Store Connect API key"
  lane :load_asc_api_key do
    asc_key = ENV["APP_STORE_CONNECT_KEY"] || ENV["ASC_PRIVATE_KEY"]
    key_id = ENV["APP_STORE_CONNECT_KEY_ID"] || ENV["ASC_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"] || ENV["ASC_ISSUER_ID"]

    UI.user_error!("Missing App Store Connect key content") if asc_key.to_s.strip.empty?
    UI.user_error!("Missing App Store Connect key id") if key_id.to_s.strip.empty?
    UI.user_error!("Missing App Store Connect issuer id") if issuer_id.to_s.strip.empty?

    is_pem = asc_key.include?("-----BEGIN")
    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: asc_key,
      is_key_content_base64: !is_pem,
      in_house: false
    )
  end

  desc "Install Flutter dependencies"
  lane :flutter_deps do
    Dir.chdir("../../") do
      sh("flutter pub get")
    end
  end

  desc "Run Flutter tests"
  lane :flutter_test do
    Dir.chdir("../../") do
      sh("flutter test")
    end
  end

  desc "Sync signing certificates and provisioning profiles"
  lane :sync_signing do
    load_asc_api_key

    match(
      type: "appstore",
      readonly: false,
      verbose: true,
      api_key_path: nil
    )
  end

  desc "Build debug iOS app"
  lane :build_debug do
    flutter_deps
    Dir.chdir("../../") do
      sh("flutter build ios --debug --no-codesign")
    end
  end

  desc "Build release iOS app for validation"
  lane :build_release do
    flutter_deps
    Dir.chdir("../../") do
      sh("flutter build ios --release --no-codesign")
    end
  end

  desc "Build signed iOS app for App Store release"
  lane :build_appstore do
    flutter_deps
    sync_signing

    Dir.chdir("../../") do
      sh("flutter build ios --release")
      sh("flutter build ipa --release")
    end
  end

  desc "Legacy beta build lane (disabled)"
  lane :build_legacy_beta do
    UI.user_error!("Legacy beta distribution is disabled for Vehicle Vitals. Use build_release/build_appstore workflows instead.")
  end

  desc "Legacy beta upload lane (disabled)"
  lane :beta do
    UI.user_error!("Legacy beta distribution is disabled for Vehicle Vitals.")
  end

  desc "Deploy to App Store"
  lane :release do
    build_appstore

    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: true,
      skip_binary_upload: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      },
      release_notes: {
        "en-US" => ENV["RELEASE_NOTES"] || "New version of Vehicle Vitals"
      }
    )
  end

  desc "Run tests and build debug version"
  lane :test_and_build do
    flutter_test
    build_debug
  end

  desc "Complete CI pipeline: test and build"
  lane :ci_pipeline do
    flutter_test
    build_release
  end

  desc "Clean build artifacts"
  lane :clean do
    Dir.chdir("../../") do
      sh("flutter clean")
      sh("rm -rf build/")
      sh("rm -rf ios/build/")
    end
  end

  error do |lane, exception|
    puts "Lane #{lane} failed with exception: #{exception.message}"
    clean if lane != :beta
  end
end
