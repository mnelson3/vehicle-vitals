# Fastfile for Wishlist Wizard iOS App
# This file contains the lanes for building, testing, and distributing the app

# Import required plugins
# fastlane add_plugin firebase_app_distribution

default_platform(:ios)

platform :ios do
  before_all do
    # Set up environment
    setup_ci if ENV['CI']

    # Ensure we're in the right directory
    Dir.chdir("../../") do
      # Any setup commands that need to run from the mobile package root
    end
  end

  desc "Load ASC API Key information to use in subsequent lanes"
  lane :load_asc_api_key do
    # Load ASC_PRIVATE_KEY from environment
    asc_raw = ENV["ASC_PRIVATE_KEY"]
    if asc_raw
      # If the secret is provided as a single-line base64 (no PEM header), prefer passing
      # it directly to Fastlane via `key_content` with `is_key_content_base64: true`.
      is_pem = asc_raw.include?("-----BEGIN")
      cleaned = asc_raw.gsub(/\s+/, "")
      looks_base64 = cleaned =~ /\A[A-Za-z0-9+\/=]+\z/ && cleaned.length > 100

      if !is_pem && looks_base64
        UI.message("Detected ASC_PRIVATE_KEY as base64; passing directly as key_content (is_key_content_base64: true)")
        app_store_connect_api_key(
          key_id: ENV["ASC_KEY_ID"],
          issuer_id: ENV["ASC_ISSUER_ID"],
          key_content: cleaned,
          is_key_content_base64: true,
          in_house: false
        )
        next
      end

      # Fall back to processing raw PEM-like content
      private_key_content = asc_raw
      # Clean up and normalize the key content
      private_key_content = private_key_content.strip
      # Remove surrounding quotes if present
      private_key_content = private_key_content.gsub(/\A['\"]|['\"]\z/, '')
      # Expand literal \n sequences into real newlines (handle secrets stored as one-liners)
      private_key_content = private_key_content.gsub(/\\n/, "\n")
      # Normalize CRLF -> LF
      private_key_content = private_key_content.gsub(/\r\n?/, "\n")
      # Strip leading/trailing whitespace from each PEM line to avoid 'bad end line' errors
      private_key_content = private_key_content.lines.map { |l| l.strip }.reject { |l| l.empty? }.join("\n") + "\n"

      # If the key doesn't have proper BEGIN/END markers, try base64 decoding
      unless private_key_content.include?("-----BEGIN PRIVATE KEY-----") || private_key_content.include?("-----BEGIN EC PRIVATE KEY-----")
        begin
          require 'base64'
          decoded = Base64.decode64(private_key_content)
          if decoded.include?("-----BEGIN")
            private_key_content = decoded
            UI.message("Decoded ASC_PRIVATE_KEY from base64")
          end
        rescue => e
          UI.message("Failed to decode ASC_PRIVATE_KEY as base64: #{e.message}")
        end
      end

      # Write the (normalized) key to a temporary file
      require 'tempfile'
      key_file = Tempfile.new(['asc_key', '.p8'])
      key_file.write(private_key_content)
      key_file.close

      UI.message("Created temporary ASC key file: #{key_file.path}")

      # Attempt multiple OpenSSL conversions to produce a canonical EC PEM that Ruby/OpenSSL accepts.
      converted_path = nil
      use_key_path = key_file.path
      begin
        require 'tmpdir'
        converted_path = File.join(Dir.tmpdir, "asc_key_converted_#{Time.now.to_i}.p8")

        conversion_cmds = [
          "openssl pkcs8 -in #{key_file.path} -inform PEM -out #{converted_path} -outform PEM -nocrypt 2>&1",
          "openssl pkey -in #{key_file.path} -out #{converted_path} -outform PEM -nocrypt 2>&1",
          "openssl ec -in #{key_file.path} -out #{converted_path} 2>&1"
        ]

        conversion_succeeded = false
        conversion_cmds.each do |cmd|
          UI.message("Trying OpenSSL command: #{cmd}")
          output = `#{cmd}`
          if $?.success? && File.exist?(converted_path) && File.size?(converted_path) && File.size(converted_path) > 0
            UI.message("OpenSSL conversion succeeded with command: #{cmd}")
            use_key_path = converted_path
            conversion_succeeded = true
            break
          else
            UI.message("OpenSSL command failed or produced empty file: #{output}")
            # Ensure no stale converted file remains
            begin; File.delete(converted_path) if File.exist?(converted_path); rescue => _; end
          end
        end
        UI.message("OpenSSL conversion overall success: #{conversion_succeeded}")
      rescue => e
        UI.message("OpenSSL conversion attempt raised: #{e.message}")
        use_key_path = key_file.path
      end

      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: use_key_path,
        in_house: false
      )

      # Clean up temporary files
      begin
        key_file.unlink
      rescue => _; end
      begin
        File.delete(converted_path) if converted_path && File.exist?(converted_path)
      rescue => _; end
    else
      UI.user_error!("ASC_PRIVATE_KEY environment variable is not set")
    end
  end

  desc "Install Flutter dependencies"
  lane :flutter_deps do
    Dir.chdir("../../") do
      sh("flutter pub get")
    end
  end

  

  desc "Run Flutter tests"
  lane :flutter_test do
    Dir.chdir("../../") do
      sh("flutter test")
    end
  end

  desc "Build Flutter iOS app in debug mode"
  lane :build_debug do
    flutter_deps
    Dir.chdir("../../") do
      sh("flutter build ios --debug --no-codesign")
    end
  end

  desc "Build Flutter iOS app in release mode"
  lane :build_release do
    flutter_deps
    Dir.chdir("../../") do
      sh("flutter build ios --release --no-codesign")
    end
  end

  desc "Sync code signing certificates and provisioning profiles"
  lane :sync_signing do
    # Sync certificates and profiles without encryption (unencrypted storage)
    # Allow installing into a specific keychain if provided by CI
    keychain_name = ENV['MATCH_KEYCHAIN_NAME']
    keychain_password = ENV['MATCH_KEYCHAIN_PASSWORD']

    match_opts = {
      type: "appstore",
      readonly: false,
      verbose: true,
      api_key_path: nil
    }
    match_opts[:keychain_name] = keychain_name
    match_opts[:keychain_path] = ENV["MATCH_KEYCHAIN_PATH"] unless ENV["MATCH_KEYCHAIN_PATH"].to_s.empty?
    match_opts[:keychain_password] = keychain_password unless keychain_password.to_s.empty?

    match(match_opts)
  end

  desc "Build and sign iOS app for App Store distribution"
  lane :build_appstore do
    flutter_deps

    # Sync signing certificates (ensures correct branch via env or Matchfile)
    sync_signing

    Dir.chdir("../../") do
      # Build the app with proper code signing
      sh("flutter build ios --release")

      # Build the Xcode project
      build_app(
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        clean: true
      )
    end
    end
  desc "Build and sign iOS app for TestFlight distribution"
  lane :build_testflight do
    flutter_deps

    # Sync signing certificates
    sync_signing

    # Install CocoaPods dependencies
    Dir.chdir("..") do
      sh("pod install")
    end

    # Build the iOS app using Flutter (includes Xcode build and IPA creation)
    Dir.chdir("../../") do
      # Ensure a clean build to avoid leftover signing artifacts
      sh("flutter clean || true")

      # Debug: list build and archive directories before build
      UI.message("Listing build/ios and build/ios/archive before build:")
      sh("ls -la build/ios || true")
      sh("ls -la build/ios/archive || true")

      # Build the IPA
      sh("flutter build ipa --release")

      # Debug: list build and archive directories after build
      UI.message("Listing build/ios and build/ios/archive after flutter build:")
      sh("ls -la build/ios || true")
      sh("ls -la build/ios/archive || true")

      # Debug: list output IPA directory so CI logs show what was produced
      UI.message("Listing generated IPA directory: build/ios/ipa")
      sh("ls -la build/ios/ipa || true")
      
      # Fallback: if no IPA was produced, try exporting from the created .xcarchive
      ipa_found = Dir["build/ios/ipa/**/*.ipa"].first
      if ipa_found.nil?
        UI.message("No .ipa found after flutter build ipa — attempting xcodebuild export from .xcarchive")
        archive = Dir["build/ios/archive/*.xcarchive"].first
        if archive.nil?
          UI.message("No .xcarchive found at build/ios/archive — cannot export IPA automatically")
        else
          UI.message("Found archive at #{archive}. Running xcodebuild -exportArchive using absolute exportOptions.plist path")
          export_plist = File.expand_path(File.join(__dir__, "exportOptions.plist"))
          UI.message("Using exportOptions.plist at #{export_plist}")
          sh("ls -la #{archive} || true")
          sh("ls -la #{archive}/Products/Applications || true")
          sh("ls -la #{archive}/Products/Applications/Runner.app/Frameworks || true")
          sh("xcodebuild -exportArchive -archivePath \"#{archive}\" -exportOptionsPlist \"#{export_plist}\" -exportPath build/ios/ipa > /tmp/xcode_export.log 2>&1 || true")
          UI.message("--- xcodebuild export log (tail) ---")
          sh("tail -n 200 /tmp/xcode_export.log || true")
          UI.message("Listing generated IPA directory after xcodebuild export")
          sh("ls -la build/ios/ipa || true")

          # Re-sign all embedded frameworks in the archive before export (workaround for codesign errors)
          UI.message("Re-signing embedded frameworks in the archive...")

          # Try to get a codesign identity from common environment variables set by match/sigh
          codesign_identity = ENV["sigh_com_nelsongrey_wishlistwizard_app_ios_appstore_certificate-name"]
          if codesign_identity.nil? || codesign_identity.to_s.empty?
            UI.message("No direct sigh env var found; searching for any sigh_* env key containing 'certificate'...")
            env_key = ENV.keys.find { |k| k.start_with?("sigh_") && k.downcase.include?("certificate") }
            codesign_identity = ENV[env_key] if env_key
            UI.message("Found env key #{env_key} => #{codesign_identity}") if env_key
          end

          # Fallback: try to detect an identity SHA from the system keychain
          if codesign_identity.nil? || codesign_identity.to_s.empty?
            UI.message("Attempting to detect a signing identity from the keychain via 'security find-identity'...")
            begin
              identity_sha = %x(security find-identity -v -p codesigning 2>/dev/null | grep -Eo '[0-9A-F]{40}' | head -n1).strip
              unless identity_sha.to_s.empty?
                codesign_identity = identity_sha
                UI.message("Detected identity SHA: #{codesign_identity}")
              end
            rescue => e
              UI.message("Error running security find-identity: #{e.message}")
            end
          end

          # If still missing, list identities and fail with a clear message
          if codesign_identity.nil? || codesign_identity.to_s.empty?
            UI.message("No codesign identity found via env or keychain. Listing available identities for debugging:")
            sh("security find-identity -v -p codesigning || true")
            UI.user_error!("No codesign identity found. Ensure match installed the certificate and the runner has access to the keychain identity.")
          end

          Dir.glob("#{archive}/Products/Applications/Runner.app/Frameworks/*.framework").each do |framework|
            UI.message("Re-signing #{framework} with identity #{codesign_identity}")
            sh("codesign --force --sign \"#{codesign_identity}\" --preserve-metadata=identifier,entitlements \"#{framework}\"")
          end
        end
      end
    end
  end

  desc "Upload to TestFlight"
  lane :beta do
    # Load App Store Connect API Key
    load_asc_api_key

    # Build the app
    build_testflight

    # Upload to TestFlight
    # Locate the generated .ipa dynamically (handles varying file names)
    # Locate the generated .ipa dynamically (handles varying file names and build dirs)
    possible_globs = [
      File.expand_path(File.join(__dir__, "..", "build", "ios", "ipa", "**", "*.ipa")),
      File.expand_path(File.join(__dir__, "..", "..", "build", "ios", "ipa", "**", "*.ipa"))
    ]
    ipa_path = nil
    possible_globs.each do |g|
      ipa_path = Dir[g].first
      break unless ipa_path.nil?
    end
    if ipa_path.nil?
      UI.user_error!("Could not find .ipa in expected locations: #{possible_globs.join(', ')}. Ensure `flutter build ipa` succeeded and produced an .ipa file.")
    else
      UI.message("Found IPA at #{ipa_path}")
    end

    # Normalize BETA contact phone to E.164-ish format for App Store Connect
    raw_contact_phone = ENV["BETA_CONTACT_PHONE"].to_s.strip
    sanitized_contact_phone = ""

    if raw_contact_phone.empty?
      UI.message("No contact phone provided; falling back to default +15551234567")
      sanitized_contact_phone = "+15551234567"
    else
      # If it starts with '+', preserve '+' then strip non-digits
      if raw_contact_phone.start_with?("+")
        digits = raw_contact_phone[1..-1].gsub(/\D/, "")
        sanitized_contact_phone = "+" + digits
      else
        # Remove non-digits
        digits = raw_contact_phone.gsub(/\D/, "")
        # If 10 digits, assume US and prefix +1
        if digits.length == 10
          sanitized_contact_phone = "+1" + digits
        else
          # If already has country code (11+ digits), prefix '+'
          if digits.length >= 11 && digits.length <= 15
            sanitized_contact_phone = "+" + digits
          else
            # Last resort fallback
            UI.message("Could not confidently normalize phone number; falling back to default +15551234567")
            sanitized_contact_phone = "+15551234567"
          end
        end
      end
    end

    # Final basic validation: must look like + followed by 7-15 digits
    unless sanitized_contact_phone.match?(/^\+\d{7,15}$/)
      UI.message("Sanitized phone didn't match expected pattern; using fallback +15551234567")
      sanitized_contact_phone = "+15551234567"
    end

    UI.message("Using contact phone for TestFlight beta metadata: ****#{sanitized_contact_phone[-4..-1]}")

    upload_options = {
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      team_id: ENV["FASTLANE_TEAM_ID"],
      beta_app_description: "Vehicle Vitals iOS Beta",
      beta_app_feedback_email: ENV["BETA_FEEDBACK_EMAIL"],
      demo_account_required: false,
      notify_external_testers: true,
      changelog: ENV["RELEASE_NOTES"] || "Bug fixes and improvements"
    }

    # Try uploading with multiple phone formats if ASC rejects the phone
    def build_review_info(phone)
      {
        contact_email: ENV["BETA_FEEDBACK_EMAIL"],
        contact_first_name: ENV["BETA_CONTACT_FIRST_NAME"] || "Mark",
        contact_last_name: ENV["BETA_CONTACT_LAST_NAME"] || "Nelson",
        contact_phone: phone,
        demo_account_name: "",
        demo_account_password: "",
        notes: "Vehicle Vitals iOS Beta Testing"
      }
    end

    # --- Upload step: perform a single binary upload (without trying multiple re-uploads) ---
    # We'll upload the IPA once (without beta_app_review_info in the guaranteed path), wait
    # for processing, and then PATCH beta review metadata via the App Store Connect API.
    # This avoids duplicate CFBundleVersion 409 errors while allowing us to retry metadata updates.
    uploaded = false
    last_error = nil

      begin
      UI.message("Uploading IPA once (without retrying full uploads).")
      # Record upload start time so we can precisely identify the uploaded build via ConnectAPI
      upload_start_time = Time.now.utc

      # Prefer to run the transporter directly so we can capture the Delivery UUID.
      # Prepare a temporary .p8 key file from ASC_PRIVATE_KEY if present.
      delivery_uuid = nil
      asc_key_id = ENV["ASC_KEY_ID"]
      asc_issuer = ENV["ASC_ISSUER_ID"]
      asc_private_key = ENV["ASC_PRIVATE_KEY"]

      if asc_key_id && asc_issuer && asc_private_key && !asc_private_key.empty?
        tmp_dir = Dir.mktmpdir("asc_key")
        begin
          p8_path = File.join(tmp_dir, "asc_key.p8")
          File.open(p8_path, "w") do |f|
            f.write(asc_private_key)
          end

          UI.message("Using direct transporter (altool) to upload IPA and capture Delivery UUID")
          cmd = "xcrun altool --upload-app --apiKey #{asc_key_id} --apiIssuer #{asc_issuer} -t ios -f \"#{ipa_path}\" -k 100000"
          # Ensure API_PRIVATE_KEYS_DIR is set so altool can find our key
          env = { 'API_PRIVATE_KEYS_DIR' => tmp_dir }
          altool_output = Actions.sh(cmd, log: true, print_command: false, env: env)
          if altool_output
            m = altool_output.match(/Delivery UUID:\s*([0-9a-fA-F\-]+)/i)
            delivery_uuid = m[1] if m
            UI.message("Transporter Delivery UUID: #{delivery_uuid}") if delivery_uuid
          end
        rescue => e
          UI.message("Direct transporter upload failed: #{e.message}; falling back to fastlane upload_to_testflight")
          upload_opts = upload_options.dup
          upload_opts.delete(:beta_app_review_info)
          upload_to_testflight(upload_opts)
        ensure
          begin
            FileUtils.remove_entry(tmp_dir) if tmp_dir && Dir.exist?(tmp_dir)
          rescue => _e; end
        end
      else
        UI.message("ASC API key not provided for direct transporter; using upload_to_testflight")
        upload_opts = upload_options.dup
        upload_opts.delete(:beta_app_review_info)
        upload_to_testflight(upload_opts)
      end

      uploaded = true
    rescue => e
      last_error = e
      UI.message("Upload failed with unexpected error: #{e.message}")
      raise
    end

    # If upload succeeded, attempt to PATCH beta review metadata (phone variants) via ConnectAPI
    if uploaded
      UI.message("Upload succeeded — attempting to set beta review metadata via App Store Connect API")

      # Helper: read CFBundleVersion and CFBundleShortVersionString from the xcarchive or built app
      def read_build_info_from_archive
        # Look for archives in likely locations (packages/mobile/build vs packages/mobile/ios/build)
        candidates = []
        candidates << File.expand_path(File.join(__dir__, "..", "..", "build", "ios", "archive", "*.xcarchive"))
        candidates << File.expand_path(File.join(__dir__, "..", "build", "ios", "archive", "*.xcarchive"))

        candidates.each do |pattern|
          Dir[pattern].each do |archive|
            next unless File.exist?(archive)
            info_plist = File.join(archive, "Products/Applications/Runner.app/Info.plist")
            if File.exist?(info_plist)
              short_version = %x(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "#{info_plist}" 2>/dev/null).strip
              build_number = %x(/usr/libexec/PlistBuddy -c "Print :CFBundleVersion" "#{info_plist}" 2>/dev/null).strip
              return {version: short_version, build: build_number}
            end
          end
        end

        # Try to extract version/build from the IPA filename or packaging summary as a last resort
        ipa_candidate = Dir[File.expand_path(File.join(__dir__, "..", "..", "build", "ios", "ipa", "**", "*.ipa"))].first
        ipa_candidate ||= Dir[File.expand_path(File.join(__dir__, "..", "build", "ios", "ipa", "**", "*.ipa"))].first
        if ipa_candidate && File.exist?(ipa_candidate)
          # Attempt to read DistributionSummary.plist sitting alongside the IPA
          dist_plist = File.join(File.dirname(ipa_candidate), "DistributionSummary.plist")
          if File.exist?(dist_plist)
            short_version = %x(/usr/libexec/PlistBuddy -c "Print :version" "#{dist_plist}" 2>/dev/null).strip
            build_number = %x(/usr/libexec/PlistBuddy -c "Print :build" "#{dist_plist}" 2>/dev/null).strip
            return {version: short_version, build: build_number}
          end
        end

        {}
      end

      build_info = read_build_info_from_archive
      app_identifier = (ENV["APP_IDENTIFIER"] || ENV["APP_ID"] || ENV["FASTLANE_APP_IDENTIFIER"] || "com.nelsongrey.wishlistwizard.app.ios")

      UI.message("Determined app identifier: #{app_identifier}")
      UI.message("Detected build info: #{build_info}")

      # Build phone variants list (preserve earlier logic but only for metadata PATCH retries)
      phone_variants = []
      if sanitized_contact_phone && sanitized_contact_phone.match(/^\+\d{7,15}$/)
        digits = sanitized_contact_phone.gsub(/\D/, "")
        phone_variants << sanitized_contact_phone
        phone_variants << digits
        if digits.length == 11 && digits.start_with?("1")
          local = digits[1..-1]
          phone_variants << "1-#{local[0,3]}-#{local[3,3]}-#{local[6,4]}"
          phone_variants << "(#{local[0,3]}) #{local[3,3]}-#{local[6,4]}"
          phone_variants << "+1 #{local[0,3]} #{local[3,3]} #{local[6,4]}"
        elsif digits.length == 10
          phone_variants << "1-#{digits[0,3]}-#{digits[3,3]}-#{digits[6,4]}"
          phone_variants << "(#{digits[0,3]}) #{digits[3,3]}-#{digits[6,4]}"
          phone_variants << "+1 #{digits[0,3]} #{digits[3,3]} #{digits[6,4]}"
        end
      end
      phone_variants = phone_variants.compact.uniq

      # Attempt to set beta review info via ConnectAPI without re-uploading the IPA.
      begin
        require 'spaceship'
        # Older Fastlane/Spaceship versions may not implement `ensure_token!`.
        # Only call it when available; otherwise assume `app_store_connect_api_key` earlier configured the client.
        if defined?(Spaceship::ConnectAPI::Token) && Spaceship::ConnectAPI::Token.respond_to?(:ensure_token!)
          Spaceship::ConnectAPI::Token.ensure_token!
        else
          UI.message('Spaceship::ConnectAPI::Token.ensure_token! not available on this Fastlane version — continuing assuming client is configured')
        end
        app = Spaceship::ConnectAPI::App.find(app_identifier)
        unless app
          UI.message("Could not find app via ConnectAPI for identifier #{app_identifier}; skipping metadata PATCH")
        else
          UI.message("Found app via ConnectAPI: #{app.id}")

          # Poll for the processed build. Try to match archive info first; otherwise pick the
          # most-recent uploaded build that was uploaded after our recorded upload_start_time.
          target_build = nil
          timeout = 600
          interval = 8
          waited = 0
          while waited < timeout && target_build.nil?
            UI.message("Polling App Store Connect for processed builds (waited #{waited}s)...")
            builds = Spaceship::ConnectAPI::Build.all(filter: {app: app.id}) rescue []
            # Try to match exact build/version from local archive info
            if build_info && build_info[:build] && build_info[:build] != ""
              target_build = builds.find { |b| b.build_version.to_s == build_info[:build].to_s }
            end
            if target_build.nil? && build_info && build_info[:version] && build_info[:version] != ""
              target_build = builds.select { |b| b.app_version.to_s == build_info[:version].to_s }.max_by { |b| (b.uploaded_date && Time.parse(b.uploaded_date) rescue Time.at(0)) }
            end

            # Fallback: choose the most recent build uploaded within the last 20 minutes
            if target_build.nil? && builds.any? && defined?(upload_start_time)
              # Prefer builds uploaded after our upload_start_time
              target_build = builds.sort_by { |b| (b.uploaded_date && Time.parse(b.uploaded_date) rescue Time.at(0)) }.reverse.find do |b|
                uploaded = (b.uploaded_date && Time.parse(b.uploaded_date) rescue Time.at(0))
                uploaded >= upload_start_time
              end
            end

            # If we found a target_build and it's in a terminal/processing state, break
            if target_build
              ps = (target_build.processing_state.to_s rescue nil)
              break if ps && %w[PROCESSING VALIDATED READY COMPLETE].include?(ps.upcase) || ps.nil?
            end

            sleep(interval)
            waited += interval
          end

          if target_build.nil?
            UI.message("Could not determine processed build for app #{app_identifier}; skipping metadata PATCH")
          else
            UI.message("Target build found: id=#{target_build.id}, version=#{target_build.app_version}, build=#{target_build.build_version}")

            # Try each phone variant, PATCHing the betaAppReviewInfo resource for the app
            patched = false
            phone_variants = ["", *phone_variants].uniq # allow empty to try clearing/omitting phone
            phone_variants.each do |pv|
              begin
                UI.message("Attempting to PATCH beta review info with phone: ****#{pv.to_s[-4..-1]}")
                body = {
                  data: {
                    type: "betaAppReviewDetails",
                    attributes: {
                      contactEmail: ENV["BETA_FEEDBACK_EMAIL"],
                      contactFirstName: ENV["BETA_CONTACT_FIRST_NAME"] || "Mark",
                      contactLastName: ENV["BETA_CONTACT_LAST_NAME"] || "Nelson",
                      contactPhone: pv.to_s,
                      demoAccountRequired: false,
                      notes: "Vehicle Vitals iOS Beta Testing"
                    }
                  }
                }
                # Use Spaceship low-level request to patch betaAppReviewDetails for the app
                path = "/v1/apps/#{app.id}/betaAppReviewDetails"
                resp = Spaceship::ConnectAPI::Base.client.patch(path, body)
                if resp && resp[:data]
                  UI.message("Successfully patched beta review info for app #{app_identifier}")
                  patched = true
                  break
                else
                  UI.message("Unexpected response while patching beta review info: #{resp.inspect}")
                end
              rescue => e
                UI.message("PATCH attempt failed: #{e.message}")
                # If response mentions contactPhone, try next variant
                next
              end
            end

            unless patched
              UI.message("All metadata PATCH attempts failed; leaving binary uploaded and skipping review info")
            end
          end
        end
      rescue => e
        UI.message("Error while attempting ConnectAPI metadata PATCH: #{e.message}")
      end
    end
  end

  desc "Deploy to App Store"
  lane :release do
    # Load App Store Connect API Key
    load_asc_api_key

    # Build the app
    build_appstore

    # Upload to App Store
    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: true,
      skip_binary_upload: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      },
      release_notes: {
        "en-US" => ENV["RELEASE_NOTES"] || "New version of Wishlist Wizard"
      }
    )
  end

  desc "Run tests and build debug version"
  lane :test_and_build do
    flutter_test
    build_debug
  end

  desc "Complete CI pipeline: test, build, and distribute to TestFlight"
  lane :ci_pipeline do
    # Run tests
    flutter_test

    # Build and upload to TestFlight
    beta
  end

  desc "Clean build artifacts"
  lane :clean do
    Dir.chdir("../../") do
      sh("flutter clean")
      sh("rm -rf build/")
      sh("rm -rf ios/build/")
    end
  end

  error do |lane, exception|
    # Handle errors - don't clean for beta lane to preserve IPA
    if lane != :beta
      puts "Lane #{lane} failed with exception: #{exception.message}"
      clean
    else
      puts "Lane #{lane} failed with exception: #{exception.message}"
    end
  end
end