# Appfile for Vehicle Vitals iOS App
# This file contains app-specific configuration for Fastlane

# The bundle identifier of your app
app_identifier("com.nelsongrey.vehiclevitals.app.ios")

# Your Apple ID email address
apple_id(ENV["FASTLANE_APPLE_ID"])

# Developer Portal Team ID
team_id(ENV["FASTLANE_TEAM_ID"])

# App Store Connect Team ID (may be different from Developer Portal Team ID)
itc_team_id(ENV["FASTLANE_ITC_TEAM_ID"])