# Environment variables for local fastlane development
# Copy this file to .env and fill in your actual values

# App Store Connect API Key
APP_STORE_CONNECT_KEY_ID=your_key_id_here
APP_STORE_CONNECT_ISSUER_ID=your_issuer_id_here
APP_STORE_CONNECT_KEY=your_base64_encoded_private_key_here

# Apple Developer Account
FASTLANE_APPLE_ID=your_apple_id@example.com
FASTLANE_TEAM_ID=your_team_id
FASTLANE_ITC_TEAM_ID=your_itc_team_id

# TestFlight
BETA_FEEDBACK_EMAIL=your_feedback_email@example.com
BETA_CONTACT_PHONE=your_contact_phone_number
