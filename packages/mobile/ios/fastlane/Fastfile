# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

# Zero-touch DevOps: Disable interactive prompts
ENV["FASTLANE_SKIP_UPDATE_CHECK"] = "1"
ENV["FASTLANE_HIDE_CHANGELOG"] = "1"
ENV["FASTLANE_DISABLE_COLORS"] = "0"

# Load environment variables from .env.local file in repository root for local development
require 'dotenv'
# Load from repository root
repo_root = File.expand_path('../../../..', __dir__)
Dotenv.load(File.join(repo_root, '.env.local')) if File.exist?(File.join(repo_root, '.env.local'))
# Also load from fastlane directory if it exists
Dotenv.load('.env') if File.exist?('.env')

default_platform(:ios)

platform :ios do
  require 'tmpdir'
  require 'shellwords'

  def ci_ios_build_number
    explicit = ENV["IOS_BUILD_NUMBER"].to_s.strip
    return explicit if explicit.match?(/\A\d+\z/) && explicit.to_i > 0

    run_id = ENV["GITHUB_RUN_ID"].to_s.strip
    return run_id if run_id.match?(/\A\d+\z/) && run_id.to_i > 0

    Time.now.utc.strftime("%Y%m%d%H%M%S")
  end

  def match_repo_write_url
    raw = ENV["MATCH_GIT_URL"].to_s.strip
    raise "MATCH_GIT_URL is not set" if raw.empty?

    pat = ENV["NELSON_GREY_PAT"].to_s.strip
    return raw if pat.empty?

    repo_path = nil
    # git@github.com:owner/repo.git
    if raw.match?(%r{\Agit@github\.com:})
      repo_path = raw.sub(%r{\Agit@github\.com:}, "").sub(%r{\.git\z}, "")
    elsif raw.match?(%r{\Ahttps?://github\.com/})
      repo_path = raw.sub(%r{\Ahttps?://github\.com/}, "").sub(%r{\.git\z}, "")
    end

    return raw if repo_path.to_s.empty?
    # Use username + PAT for write operations; keep logging disabled when running git.
    "https://mnelson3:#{pat}@github.com/#{repo_path}.git"
  end

  def purge_match_repo_appstore_assets!
    UI.important("🧹 Purging appstore signing assets from match repo...")
    git_url = match_repo_write_url

    repo_dir = Dir.mktmpdir("match-repo-")

    begin
      sh("git clone #{git_url.shellescape} #{repo_dir.shellescape}", log: false)
      sh("cd #{repo_dir.shellescape} && git checkout main", log: false)

      # Remove appstore provisioning profiles and distribution certs so match is forced to regenerate.
      sh("cd #{repo_dir.shellescape} && rm -f profiles/appstore/*.mobileprovision || true", log: false)
      sh("cd #{repo_dir.shellescape} && rm -f certs/distribution/*.cer certs/distribution/*.p12 || true", log: false)

      status = sh("cd #{repo_dir.shellescape} && git status --porcelain", log: false)
      return if status.to_s.strip.empty?

      sh("cd #{repo_dir.shellescape} && git add -A", log: false)
      sh(
        "cd #{repo_dir.shellescape} && git -c user.email=ci@vehicle-vitals.local -c user.name=vehicle-vitals-ci commit -m \"CI: purge appstore signing assets\"",
        log: false
      )
      sh("cd #{repo_dir.shellescape} && git push origin main", log: false)
      UI.important("✅ Purged appstore signing assets in match repo")
    ensure
      sh("rm -rf #{repo_dir.shellescape}", log: false)
    end
  end

  def match_keychain_path
    ENV["MATCH_KEYCHAIN_PATH"].to_s.empty? ? match_keychain_name : ENV["MATCH_KEYCHAIN_PATH"]
  end

  def match_keychain_name
    ENV["MATCH_KEYCHAIN_NAME"].to_s.empty? ? "fastlane_tmp_keychain" : ENV["MATCH_KEYCHAIN_NAME"]
  end

  def match_keychain_password
    return ENV["MATCH_KEYCHAIN_PASSWORD"] unless ENV["MATCH_KEYCHAIN_PASSWORD"].to_s.empty?
    return ENV["MATCH_PASSWORD"] unless ENV["MATCH_PASSWORD"].to_s.empty?
    ""
  end

  def unlock_match_keychain
    return if match_keychain_password.to_s.empty?
    sh("security unlock-keychain -p \"#{match_keychain_password}\" \"#{match_keychain_path}\" || true")
  end

  def match_keychain_has_codesigning_identities?
    output = sh("security find-identity -v -p codesigning \"#{match_keychain_path}\" || true", log: false)
    return false if output.to_s.include?("0 valid identities found")
    output.to_s.match?(/\b[1-9][0-9]*\b valid identities found/)
  end

  def ensure_match_installed_identity!(type:, app_identifier: nil, api_key: nil)
    unlock_match_keychain
    return if match_keychain_has_codesigning_identities?

    UI.important("⚠️  No valid code signing identities found in keychain after match (#{type}). Re-running match with readonly: false to generate/import a certificate + private key.")

    args = {
      type: type,
      readonly: false,
      keychain_name: match_keychain_name,
      keychain_password: match_keychain_password,
      skip_set_partition_list: false,
      include_all_certificates: true,
      # Identity recovery should focus on cert/key material. Profile decoding/install
      # can fail in CI with `security cms` "Write permissions" errors.
      skip_provisioning_profiles: true,
      verbose: true
    }

    # `force_for_new_certificates` is only meaningful for development.
    # For appstore signing, Fastlane warns that this flag is ignored.
    if type.to_s == "development"
      args[:force_for_new_certificates] = true
    end
    args[:app_identifier] = app_identifier if app_identifier
    if api_key
      args[:api_key] = api_key
    else
      args[:username] = ENV["FASTLANE_APPLE_ID"]
      args[:team_id] = ENV["FASTLANE_TEAM_ID"]
    end

    begin
      match(**args)
    rescue Exception => e
      message = e.message.to_s
      printable = e.to_s

      UI.important("⚠️  match(#{type}) raised #{e.class}: #{message}")

      max_cert_reached = message.match?(/Could not create another Distribution certificate|reached the maximum number of available Distribution certificates/i)

      portal_drift = (
        (message.include?("stored in your storage") || printable.include?("stored in your storage")) &&
          (message.include?("not available on the Developer Portal") || printable.include?("not available on the Developer Portal"))
      )

      # match often emits a generic FastlaneError suggesting `match nuke` after printing
      # the more specific portal drift details. Treat that as portal drift in CI.
      portal_drift ||= message.match?(/reset the certificates of your apple account|fastlane match nuke/i)

      if type.to_s == "appstore" && max_cert_reached
        UI.important("⚠️  Distribution certificate quota reached. Nuking appstore signing assets on the Developer Portal and retrying match.")
        match_nuke_args = { type: type }
        match_nuke_args[:app_identifier] = app_identifier if app_identifier
        match_nuke_args[:skip_confirmation] = true
        if api_key
          match_nuke_args[:api_key] = api_key
        else
          match_nuke_args[:username] = ENV["FASTLANE_APPLE_ID"]
          match_nuke_args[:team_id] = ENV["FASTLANE_TEAM_ID"]
        end

        match_nuke(**match_nuke_args)
        begin
          purge_match_repo_appstore_assets!
        rescue Exception => purge_err
          UI.important("⚠️  Post-nuke match repo purge failed (#{purge_err.class}). Continuing...")
        end
        match(**args.merge(force: true, skip_provisioning_profiles: false))
      elsif type.to_s == "appstore" && portal_drift
        UI.important("⚠️  match storage contains revoked certs. Purging appstore assets from match repo and regenerating.")
        begin
          purge_match_repo_appstore_assets!
          match(**args.merge(force: true, skip_provisioning_profiles: false))
        rescue Exception => purge_err
          UI.important("⚠️  Purge/regenerate failed (#{purge_err.class}). Retrying match once with skip_certificate_matching: true, force: true.")
          match(**args.merge(force: true, skip_certificate_matching: true))
        end
      elsif message.match?(/permission denied|publickey|access denied|push|write access/i) || printable.match?(/permission denied|publickey|access denied|push|write access/i)
        # If CI only has read access to the match repo, still try to generate/import locally
        # so the pipeline can proceed (this won't persist certs back to the repo).
        UI.important("⚠️  match failed while trying to write to the certificates repo. Retrying once with skip_git_push: true so CI can proceed.")
        match(**args.merge(skip_git_push: true))
      else
        raise e
      end
    end

    unlock_match_keychain
    if !match_keychain_has_codesigning_identities? && type.to_s == "appstore"
      UI.important("⚠️  Still no identities after appstore match recovery. Escalating to match(force: true) to renew signing assets.")
      match(**args.merge(force: true))
      unlock_match_keychain
    end

    # True zero-touch: if the match repo contains certs but no usable identity (missing private key),
    # force a self-heal by purging appstore signing assets from the repo and regenerating via match.
    if !match_keychain_has_codesigning_identities? && type.to_s == "appstore" && ENV["VV_MATCH_NUKE_ON_IDENTITY_FAILURE"].to_s == "1"
      UI.important("🧨 VV_MATCH_NUKE_ON_IDENTITY_FAILURE=1 and still no identities. Purging appstore assets from match repo and regenerating.")
      purge_match_repo_appstore_assets!
      match(**args.merge(force: true, skip_provisioning_profiles: false))
      unlock_match_keychain
    end

    unless match_keychain_has_codesigning_identities?
      UI.important("⚠️  No valid identities found after match recovery. Collecting keychain diagnostics...")
      sh("security default-keychain -d user || true")
      sh("security list-keychains -d user || true")
      sh("security find-identity -v -p codesigning || true")
      sh("security find-identity -v -p codesigning \"#{match_keychain_path}\" || true")
      sh("security find-certificate -a -Z -c \"Apple Development\" \"#{match_keychain_path}\" || true")
      sh("security find-certificate -a -Z -c \"Apple Distribution\" \"#{match_keychain_path}\" || true")
      raise "match completed but no valid code signing identities are available in #{match_keychain_path}"
    end
  end

  desc "Distribute iOS app to Firebase App Distribution"
  lane :distribute do |options|
    build_type = options[:build_type] || "debug"
    release_notes = options[:release_notes] || "Automated build from CI/CD"
    tester_groups = options[:tester_groups] || "internal-testers"

    # Build the Flutter iOS app with AdMob configuration
    build_cmd = "cd ../.. && flutter build ios --#{build_type} --no-codesign"
    
    # Add AdMob environment variables for production builds
    if ENV["ADMOB_BANNER_UNIT_ID"] && build_type == "release"
      build_cmd += " --dart-define=ADMOB_BANNER_UNIT_ID=\"#{ENV["ADMOB_BANNER_UNIT_ID"]}\""
      build_cmd += " --dart-define=ADMOB_INTERSTITIAL_UNIT_ID=\"#{ENV["ADMOB_INTERSTITIAL_UNIT_ID"]}\""
      build_cmd += " --dart-define=ADMOB_REWARDED_UNIT_ID=\"#{ENV["ADMOB_REWARDED_UNIT_ID"]}\""
    end
    
    sh(build_cmd)

    # Create IPA using Xcode build
    build_app(
      scheme: "Runner",
      configuration: build_type.capitalize,
      export_method: "development",
      output_directory: "./fastlane/builds",
      output_name: "Vehicle-Vitals-#{build_type}.ipa",
      clean: true,
      skip_package_ipa: false
    )

    # Distribute to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["IOS_APP_ID"] || "1:489413148337:ios:b55d0b37718e299368ac90",
      service_credentials_file: ENV["IOS_SERVICE_ACCOUNT_KEY_FILE"] || "../service-account-key.json",
      groups: tester_groups,
      release_notes: release_notes
    )
  end

  desc "Distribute debug build to internal testers"
  lane :debug do
    # Build without code signing for development
    build_development

    UI.message("Development build completed successfully!")
    UI.message("Note: Code signing setup is pending. The app can be:")
    UI.message("1. Installed on jailbroken devices")
    UI.message("2. Manually signed for testing")
    UI.message("3. Deployed once proper certificates are available")

    # Skip Firebase distribution for now due to code signing requirements
    # TODO: Re-enable once certificates are properly configured
    # firebase_app_distribution(
    #   app: ENV["IOS_APP_ID"] || "1:489413148337:ios:b55d0b37718e299368ac90",
    #   service_credentials_file: ENV["IOS_SERVICE_ACCOUNT_KEY_FILE"] || "../service-account-key.json",
    #   groups: "internal-testers",
    #   release_notes: "Debug build for internal testing (no code signing)",
    #   ipa_path: "./fastlane/builds/Vehicle-Vitals-debug.ipa"
    # )
  end

  desc "Sync code signing certificates"
  lane :sync_signing do
    # Debug: Print environment variables
    UI.message("MATCH_GIT_URL: #{ENV["MATCH_GIT_URL"]}")
    UI.message("FASTLANE_APPLE_ID: #{ENV["FASTLANE_APPLE_ID"]}")
    UI.message("FASTLANE_TEAM_ID: #{ENV["FASTLANE_TEAM_ID"]}")

    # For now, use username/password authentication due to spaceship OpenSSL compatibility issues
    # TODO: Switch back to API key authentication once spaceship is fixed
    match(
      type: "appstore",
      readonly: true,
      username: ENV["FASTLANE_APPLE_ID"],
      team_id: ENV["FASTLANE_TEAM_ID"],
      keychain_name: match_keychain_name,
      keychain_password: match_keychain_password,
      skip_set_partition_list: false,
      verbose: true
    )

    ensure_match_installed_identity!(type: "appstore")
  end

  desc "Generate development certificates"
  lane :certificates_development do
    # Try API key authentication first (works better with 2FA)
    private_key_content = ENV["ASC_PRIVATE_KEY"]
    if private_key_content && !private_key_content.empty? && private_key_content != "your_asc_private_key"
      private_key_content = private_key_content.gsub("\0", "").gsub("%", "").strip

      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: private_key_content,
        is_key_content_base64: true
      )

      begin
        match(
          type: "development",
          readonly: true,
          api_key: api_key,
          keychain_name: match_keychain_name,
          keychain_password: match_keychain_password,
          skip_set_partition_list: false
        )
        UI.success("✅ Zero-touch success: Using existing development certificates")
      rescue => e
        if e.message.include?("No code signing identity found")
          UI.message("⚠️  No existing development certificates found. Creating new ones...")
          match(
            type: "development",
            readonly: false,
            api_key: api_key,
            keychain_name: match_keychain_name,
            keychain_password: match_keychain_password,
            skip_set_partition_list: false
          )
          UI.success("✅ Created new development certificates successfully")
        else
          raise e
        end
      end

      ensure_match_installed_identity!(type: "development", api_key: api_key)
    else
      # Fall back to username/password authentication
      UI.message("API key not available, using username/password authentication")
      UI.message("Note: If you have 2FA enabled, use an app-specific password")
      begin
        match(
          type: "development",
          readonly: true,
          username: ENV["FASTLANE_APPLE_ID"],
          team_id: ENV["FASTLANE_TEAM_ID"],
          keychain_name: match_keychain_name,
          keychain_password: match_keychain_password,
          skip_set_partition_list: false
        )
        UI.success("✅ Zero-touch success: Using existing development certificates")
      rescue => e
        if e.message.include?("No code signing identity found")
          UI.message("⚠️  No existing development certificates found. Creating new ones...")
          match(
            type: "development",
            readonly: false,
            username: ENV["FASTLANE_APPLE_ID"],
            team_id: ENV["FASTLANE_TEAM_ID"],
            keychain_name: match_keychain_name,
            keychain_password: match_keychain_password,
            skip_set_partition_list: false
          )
          UI.success("✅ Created new development certificates successfully")
        else
          raise e
        end
      end

      ensure_match_installed_identity!(type: "development")
    end
  end

  desc "Zero-touch certificate management - automatically handles certificate acquisition and sharing"
  lane :certificates_appstore do
    # Zero-touch DevOps: Most efficient certificate strategy
    # 1. Check for existing valid certificates in shared repo
    # 2. Reuse certificates across multiple apps (most efficient)
    # 3. Only create new certificates when necessary
    # 4. Support certificate sharing across all projects

    private_key_content = ENV["ASC_PRIVATE_KEY"]
    if private_key_content && !private_key_content.empty? && private_key_content != "your_asc_private_key"
      private_key_content = private_key_content.gsub("\0", "").gsub("%", "").strip

      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: private_key_content,
        is_key_content_base64: true
      )

      # Most efficient zero-touch strategy: Smart certificate reuse
      # Use readonly mode to avoid creating new certificates
      UI.message("🚀 Most efficient zero-touch: Using existing certificates (readonly mode)")

      begin
        match(
          type: "appstore",
          readonly: true,
          app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
          api_key: api_key,
          keychain_name: match_keychain_name,
          keychain_password: match_keychain_password,
          skip_set_partition_list: false
        )
        UI.success("✅ Zero-touch success: Using existing certificates from shared repository")
        UI.message("💡 Maximum efficiency achieved: No new certificates created")
      rescue => e
        quota_reached = e.message.to_s.match?(/Could not create another Distribution certificate|reached the maximum number of available Distribution certificates/i)

        if e.message.to_s.include?("stored in your storage") && e.message.to_s.include?("not available on the Developer Portal")
          UI.important("⚠️  match storage contains revoked certs. Purging appstore assets from match repo and regenerating.")
          purge_match_repo_appstore_assets!
          begin
            match(
              type: "appstore",
              readonly: false,
              force: true,
              app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
              api_key: api_key,
              keychain_name: match_keychain_name,
              keychain_password: match_keychain_password,
              skip_set_partition_list: false
            )
            UI.success("✅ Repaired revoked certificates and regenerated signing assets")
          rescue => regen_err
            if regen_err.message.to_s.match?(/Could not create another Distribution certificate|reached the maximum number of available Distribution certificates/i)
              UI.important("⚠️  Distribution certificate quota reached while regenerating. Nuking appstore signing assets on the Developer Portal and retrying match.")
              match_nuke(
                type: "appstore",
                app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
                api_key: api_key,
                skip_confirmation: true
              )
              begin
                purge_match_repo_appstore_assets!
              rescue Exception => purge_err
                UI.important("⚠️  Post-nuke match repo purge failed (#{purge_err.class}). Continuing...")
              end
              match(
                type: "appstore",
                readonly: false,
                force: true,
                app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
                api_key: api_key,
                keychain_name: match_keychain_name,
                keychain_password: match_keychain_password,
                skip_set_partition_list: false,
                verbose: true
              )
              UI.success("✅ Recovered from certificate quota by nuking and regenerating signing assets")
            else
              raise regen_err
            end
          end
        elsif e.message.include?("No code signing identity found")
          UI.message("⚠️  No existing certificates found. Creating new ones...")
          begin
            match(
              type: "appstore",
              readonly: false,
              app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
              api_key: api_key,
              keychain_name: match_keychain_name,
              keychain_password: match_keychain_password,
              skip_set_partition_list: false,
              verbose: true
            )
            UI.success("✅ Created new certificates successfully")
          rescue => regen_err
            if regen_err.message.to_s.match?(/Could not create another Distribution certificate|reached the maximum number of available Distribution certificates/i)
              UI.important("⚠️  Distribution certificate quota reached. Nuking appstore signing assets on the Developer Portal and retrying match.")
              match_nuke(
                type: "appstore",
                app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
                api_key: api_key,
                skip_confirmation: true
              )
              begin
                purge_match_repo_appstore_assets!
              rescue Exception => purge_err
                UI.important("⚠️  Post-nuke match repo purge failed (#{purge_err.class}). Continuing...")
              end
              match(
                type: "appstore",
                readonly: false,
                force: true,
                app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
                api_key: api_key,
                keychain_name: match_keychain_name,
                keychain_password: match_keychain_password,
                skip_set_partition_list: false,
                verbose: true
              )
              UI.success("✅ Recovered from certificate quota by nuking and regenerating signing assets")
            else
              raise regen_err
            end
          end
        elsif quota_reached
          UI.important("⚠️  Distribution certificate quota reached. Nuking appstore signing assets on the Developer Portal and retrying match.")
          match_nuke(
            type: "appstore",
            app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
            api_key: api_key,
            skip_confirmation: true
          )
          begin
            purge_match_repo_appstore_assets!
          rescue Exception => purge_err
            UI.important("⚠️  Post-nuke match repo purge failed (#{purge_err.class}). Continuing...")
          end
          match(
            type: "appstore",
            readonly: false,
            force: true,
            app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
            api_key: api_key,
            keychain_name: match_keychain_name,
            keychain_password: match_keychain_password,
            skip_set_partition_list: false,
            verbose: true
          )
          UI.success("✅ Recovered from certificate quota by nuking and regenerating signing assets")
        else
          raise e
        end
      end

      ensure_match_installed_identity!(
        type: "appstore",
        app_identifier: ["com.nelsongrey.vehiclevitals.app.ios"],
        api_key: api_key
      )
    else
      # Fallback for when API key is not available
      UI.message("🔑 API key not available, using username/password authentication")
      UI.message("📝 Note: For zero-touch efficiency, configure ASC_PRIVATE_KEY environment variable")

      match(
        type: "appstore",
        readonly: true,  # Be conservative with certificate creation
        username: ENV["FASTLANE_APPLE_ID"],
        team_id: ENV["FASTLANE_TEAM_ID"],
        keychain_name: match_keychain_name,
        keychain_password: match_keychain_password,
        skip_set_partition_list: false
      )

      ensure_match_installed_identity!(type: "appstore")
    end
  end
  lane :certificates_all do
    certificates_development
    certificates_appstore
  end

  desc "Build iOS app for development without code signing"
  lane :build_development do
    build_number = ci_ios_build_number
    UI.message("Using iOS build number: #{build_number}")
    # Build the Flutter iOS app without code signing for development
    sh("cd ../.. && flutter build ios --debug --no-codesign --build-number=#{build_number}")

    # For development builds without certificates, just copy the .app file
    # Firebase App Distribution can accept .app files for development
    app_path = "../../build/ios/iphoneos/Runner.app"
    output_dir = "./fastlane/builds"
    sh("mkdir -p #{output_dir}")
    sh("cp -r #{app_path} #{output_dir}/")

    UI.message("Development build completed. App available at: #{output_dir}/Runner.app")
    UI.message("Note: This app is not code signed and can only be installed on jailbroken devices or with manual signing")
  end

  desc "Build iOS app for TestFlight with proper code signing"
  lane :build_testflight do
    UI.important("⚠️  This lane is deprecated. Use 'beta' lane instead for complete TestFlight upload.")
    UI.message("The 'beta' lane now handles both building and uploading to TestFlight.")
    UI.message("This lane will be removed in a future update.")
  end

  desc "Upload to TestFlight"
  lane :beta do |options|
    release_notes = options[:release_notes] || "Automated build for TestFlight"
    feedback_email = ENV["BETA_FEEDBACK_EMAIL"] || "mark.a.nelson@outlook.com"

    build_number = ci_ios_build_number
    UI.message("Using iOS build number: #{build_number}")

    # Sync code signing certificates for TestFlight (distribution/appstore).
    # Development certificates are not required for an unsigned Flutter build + later resign.
    certificates_appstore

    # Set environment variables for manual code signing in Flutter build
    ENV['PROVISIONING_PROFILE'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore']
    ENV['CODE_SIGN_IDENTITY'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_certificate-name']
    ENV['DEVELOPMENT_TEAM'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_team-id']

    # Install CocoaPods dependencies first
    sh("bundle exec pod install")

    # Build the Flutter iOS app without code signing
    sh("cd ../.. && flutter build ios --release --no-codesign --build-number=#{build_number}")

    # Create unsigned IPA from the app with proper structure
    sh("mkdir -p ./builds")
    sh("mkdir -p Payload")
    sh("cp -r ../../build/ios/iphoneos/Runner.app Payload/")
    sh("zip -r ./builds/Vehicle-Vitals.ipa Payload/")
    sh("rm -rf Payload")

    # Wait for IPA to be fully written
    sh("while [ ! -f ./builds/Vehicle-Vitals.ipa ] || [ ! -s ./builds/Vehicle-Vitals.ipa ]; do sleep 1; done")

    # Diagnostics: keychain + signing identities just before resign
    UI.message("MATCH_KEYCHAIN_NAME: #{ENV['MATCH_KEYCHAIN_NAME']}")
    UI.message("MATCH_KEYCHAIN_PATH: #{ENV['MATCH_KEYCHAIN_PATH']}")
    sh("security default-keychain -d user || true")
    sh("security list-keychains -d user || true")
    sh("security find-identity -v -p codesigning || true")
    if ENV['MATCH_KEYCHAIN_PATH'] && !ENV['MATCH_KEYCHAIN_PATH'].empty?
      sh("security find-identity -v -p codesigning \"#{ENV['MATCH_KEYCHAIN_PATH']}\" || true")
    end

    # Sign the IPA using fastlane resign
    ipa_path = File.expand_path("./builds/Vehicle-Vitals.ipa")
    resign(
      ipa: ipa_path,
      signing_identity: (ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_certificate-name'] || "Apple Distribution: Mark Nelson (P6YJUBML6P)"),
      provisioning_profile: ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_profile-path'],
      keychain_path: ENV['MATCH_KEYCHAIN_PATH']
    )

    # Set up API key authentication
    private_key_content = ENV["ASC_PRIVATE_KEY"]
    if private_key_content.nil? || private_key_content.empty?
      UI.error("ASC_PRIVATE_KEY environment variable is not set or empty")
      raise "Missing ASC_PRIVATE_KEY"
    end
    private_key_content = private_key_content.gsub("\0", "").gsub("%", "").strip

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: private_key_content,
      is_key_content_base64: true
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: false,
      changelog: release_notes,
      beta_app_feedback_email: feedback_email,
      beta_app_description: "Vehicle Vitals iOS App - Automated Build"
    )

    UI.message("✅ Flutter iOS build completed successfully")
    UI.message("📦 IPA file uploaded to TestFlight")
  end

  desc "Submit app to App Store"
  lane :submit_to_app_store do |options|
    release_notes = options[:release_notes] || "Automated App Store submission"

    build_number = ci_ios_build_number
    UI.message("Using iOS build number: #{build_number}")

    # Sync code signing certificates for App Store
    certificates_appstore

    # Set environment variables for manual code signing in Flutter build
    ENV['PROVISIONING_PROFILE'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore']
    ENV['CODE_SIGN_IDENTITY'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_certificate-name']
    ENV['DEVELOPMENT_TEAM'] = ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_team-id']

    # Install CocoaPods dependencies first
    sh("bundle exec pod install")

    # Build the Flutter iOS app without code signing
    sh("cd ../.. && flutter build ios --release --no-codesign --build-number=#{build_number}")

    # Create unsigned IPA from the app with proper structure
    sh("mkdir -p ./builds")
    sh("mkdir -p Payload")
    sh("cp -r ../../build/ios/iphoneos/Runner.app Payload/")
    sh("zip -r ./builds/Vehicle-Vitals-AppStore.ipa Payload/")
    sh("rm -rf Payload")

    # Wait for IPA to be fully written
    sh("while [ ! -f ./builds/Vehicle-Vitals-AppStore.ipa ] || [ ! -s ./builds/Vehicle-Vitals-AppStore.ipa ]; do sleep 1; done")

    # Sign the IPA using fastlane resign
    ipa_path = File.expand_path("./builds/Vehicle-Vitals-AppStore.ipa")
    resign(
      ipa: ipa_path,
      signing_identity: (ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_certificate-name'] || "Apple Distribution: Mark Nelson (P6YJUBML6P)"),
      provisioning_profile: ENV['sigh_com.nelsongrey.vehiclevitals.app.ios_appstore_profile-path'],
      keychain_path: ENV['MATCH_KEYCHAIN_PATH']
    )

    # Set up API key authentication
    private_key_content = ENV["ASC_PRIVATE_KEY"]
    if private_key_content.nil? || private_key_content.empty?
      UI.error("ASC_PRIVATE_KEY environment variable is not set or empty")
      raise "Missing ASC_PRIVATE_KEY"
    end
    private_key_content = private_key_content.gsub("\0", "").gsub("%", "").strip

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: private_key_content,
      is_key_content_base64: true
    )

    # Submit to App Store
    deliver(
      api_key: api_key,
      ipa: ipa_path,
      skip_screenshots: true,
      skip_metadata: true,
      skip_app_version_update: false,
      force: true,
      submit_for_review: true,
      automatic_release: false,
      release_notes: release_notes
    )

    UI.message("✅ App submitted to App Store successfully")
  end

  desc "Complete release pipeline: TestFlight + App Store"
  lane :full_release_pipeline do |options|
    release_notes = options[:release_notes] || "Automated full release"
    manage_beta = options[:manage_beta] || false
    beta_group_name = options[:beta_group_name] || "Internal Testers"
    submit_to_app_store = options[:submit_to_app_store] || false

    UI.message("🚀 Starting full release pipeline...")

    # Always upload to TestFlight
    beta(release_notes: release_notes)

    if manage_beta
      UI.message("📝 Managing TestFlight beta groups...")
      # Set up API key authentication for beta management
      private_key_content = ENV["ASC_PRIVATE_KEY"]
      private_key_content = private_key_content.gsub("\0", "").gsub("%", "").strip

      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: private_key_content,
        is_key_content_base64: true
      )

      # Add to beta group if specified
      if beta_group_name && !beta_group_name.empty?
        pilot(
          api_key: api_key,
          distribute_external: true,
          groups: [beta_group_name],
          skip_waiting_for_build_processing: false,
          changelog: release_notes
        )
      end
    end

    if submit_to_app_store
      UI.message("🏪 Submitting to App Store...")
      submit_to_app_store(release_notes: release_notes)
    end

    UI.message("✅ Full release pipeline completed successfully")
  end
end