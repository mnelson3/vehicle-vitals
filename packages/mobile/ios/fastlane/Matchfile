git_url(ENV["MATCH_GIT_URL"] || "https://github.com/mnelson3/nelson-grey")
git_branch(ENV["MATCH_GIT_BRANCH"] || "develop")
storage_mode("git")
type(ENV["MATCH_TYPE"] || "appstore")

# Avoid hard-coding Apple identifiers in-repo; prefer workflow secrets.
username(ENV["FASTLANE_APPLE_ID"]) if ENV["FASTLANE_APPLE_ID"]
team_id(ENV["FASTLANE_TEAM_ID"]) if ENV["FASTLANE_TEAM_ID"]

force_for_new_devices(true)
skip_set_partition_list(false)
