{
  "name": "@shared/firebase-utils",
  "version": "1.0.0",
  "description": "Shared Firebase utilities for Firebase-first architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "test": "if [ -d \"tests\" ] && [ \"$(find tests -name '*.test.*' -o -name '*.spec.*' | wc -l)\" -gt 0 ]; then vitest; else echo 'No test files found, skipping tests'; fi",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "firebase-admin": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.9.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "firebase": "^12.16.0"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
