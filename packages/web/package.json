{
  "name": "@vehicle-vitals/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "./scripts/vite-sanitized-env.sh dev development",
    "build": "./scripts/vite-sanitized-env.sh build production",
    "build:staging": "./scripts/vite-sanitized-env.sh build staging",
    "build:development": "./scripts/vite-sanitized-env.sh build development",
    "build:demonstration": "./scripts/vite-sanitized-env.sh build demonstration",
    "build:production": "./scripts/vite-sanitized-env.sh build production",
    "preview": "./scripts/vite-sanitized-env.sh preview production",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:emulator": "firebase emulators:exec --only firestore,functions,hosting,dataconnect --project vehicle-vitals-dev 'npm run test'",
    "test:uat": "playwright test",
    "test:uat:chromium": "playwright test --project=chromium tests/uat.spec.ts",
    "test:uat:firefox": "playwright test --project=firefox tests/uat.spec.ts",
    "test:uat:webkit": "playwright test --project=webkit tests/uat.spec.ts",
    "test:uat:all": "playwright test tests/uat.spec.ts",
    "test:uat:headed": "playwright test --headed",
    "test:uat:debug": "playwright test --debug",
    "test:uat:report": "playwright show-report test-results-html",
    "test:quality": "npm run test:unit && npm run test:uat:chromium",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "check": "tsc --noEmit",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "@vehicle-vitals/shared": "file:../shared",
    "firebase": "^12.3.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.8",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.6.3",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
