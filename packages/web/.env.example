# Firebase Configuration
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=vehicle-vitals-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=vehicle-vitals-dev
VITE_FIREBASE_STORAGE_BUCKET=your-bucket-name
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Environment Settings
VITE_ENVIRONMENT=development
VITE_USE_FIREBASE_EMULATORS=false
VITE_DEBUG=true
VITE_SHOW_COMING_SOON=false

# Analytics & Monitoring
VITE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Third-party Services
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT=XXXXXXXXXX

# Environment Access Gate (required for staging/development gate)
VITE_ACCESS_PASSWORD_STAGING=REPLACE_WITH_STAGING_PASSWORD
VITE_ACCESS_PASSWORD_DEVELOPMENT=REPLACE_WITH_DEVELOPMENT_PASSWORD

# Feature Flags
VITE_ENABLE_DEBUG_TOOLS=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_ADS=false
VITE_ENABLE_HOSTED_DEMO_PDF_UPLOADS=false

# Usage:
# - Copy this file to .env.development, .env.staging, or .env.production as needed
# - Vite exposes variables prefixed with VITE_ to the client code
# - Set VITE_ENVIRONMENT to development|staging|production and ensure VITE_FIREBASE_PROJECT_ID matches
#   development -> vehicle-vitals-dev
#   staging -> vehicle-vitals-staging
#   production -> vehicle-vitals-prod
# - Set VITE_USE_FIREBASE_EMULATORS=true only for intentional local emulator sessions
# - VITE_SHOW_COMING_SOON=true will show the Coming Soon page instead of the full app
# - Set VITE_ENABLE_HOSTED_DEMO_PDF_UPLOADS=true only after bucket CORS allows
#   https://vehicle-vitals-dev.web.app for browser uploads.
# - VITE_ENABLE_ADS defaults to enabled only for production/prod project alignment;
#   set true/false to explicitly override behavior for a specific environment.