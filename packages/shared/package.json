{
  "name": "@vehicle-vitals/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./vehicleHealth": {
      "types": "./dist/vehicleHealth.d.ts",
      "import": "./dist/vehicleHealth.js"
    },
    "./maintenanceSchedules": {
      "types": "./dist/maintenanceSchedules.d.ts",
      "import": "./dist/maintenanceSchedules.js"
    },
    "./vehiclePortfolio": {
      "types": "./dist/vehiclePortfolio.d.ts",
      "import": "./dist/vehiclePortfolio.js"
    },
    "./ownershipInsights": {
      "types": "./dist/ownershipInsights.d.ts",
      "import": "./dist/ownershipInsights.js"
    },
    "./vinValidation": {
      "types": "./dist/vinValidation.d.ts",
      "import": "./dist/vinValidation.js"
    },
    "./documentAnalysisSummary": {
      "types": "./dist/documentAnalysisSummary.d.ts",
      "import": "./dist/documentAnalysisSummary.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "test": "if [ -d \"tests\" ] && [ \"$(find tests -name '*.test.*' -o -name '*.spec.*' | wc -l)\" -gt 0 ]; then vitest; else echo 'No test files found, skipping tests'; fi",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "firebase": "^12.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
