{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "test": "npm run build && FIREBASE_CONFIG='{\"projectId\":\"vehicle-vitals-dev\",\"storageBucket\":\"vehicle-vitals-dev.firebasestorage.app\",\"locationId\":\"us-central1\"}' GCLOUD_PROJECT=vehicle-vitals-dev node --test test/**/*.test.js",
    "seed:demo-data": "node scripts/seed-demo-data.js",
    "purge:demo-data": "node scripts/purge-demo-data.js",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.5.0",
    "natural-compare-lite": "^1.4.0",
    "tsutils": "^3.21.0",
    "typescript": "^6.0.3"
  },
  "private": true,
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    },
    "js-yaml": "^4.2.0",
    "uuid": "11.1.1"
  }
}
