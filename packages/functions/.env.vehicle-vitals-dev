# Integration provider feature flags — see docs/ENVIRONMENT_SETUP.md.
# These default to off/"none" in code (packages/functions/src/integrations.config.ts)
# as a safe fail-closed default; this file is what actually turns them on for
# this deployed project. None of the four require external secrets — manuals
# and warranty call NHTSA's free public API (same as the VIN lookup already
# in production), maintenance plan and calendar are pure local computation.
MANUALS_ENABLED=true
MANUALS_PROVIDER=manuals_primary
WARRANTY_ENABLED=true
WARRANTY_PROVIDER=warranty_primary
MAINTENANCE_PLAN_ENABLED=true
SCHEDULE_PROVIDER=schedule_primary
CALENDAR_ENABLED=true
CALENDAR_PROVIDER=calendar_primary
