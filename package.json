{
  "name": "vehicle-vitals-monorepo",
  "private": true,
  "description": "Root workspace for Vehicle Vitals (web + mobile)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:production": "npm run build --workspace=@vehicle-vitals/web",
    "build:staging": "npm run build:staging --workspace=@vehicle-vitals/web",
    "build:development": "npm run build:development --workspace=@vehicle-vitals/web",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "build:web": "npm run build --workspace=@vehicle-vitals/web",
    "dev:web": "npm run dev --workspace=@vehicle-vitals/web",
    "test:web": "npm run test --workspace=@vehicle-vitals/web",
    "export:logo": "node scripts/export-logo.js",
    "dataconnect:codegen": "node scripts/dataconnect-codegen.js",
    "install:all": "npm install",
    "install:clean": "./tools/clean.sh && ./tools/install.sh",
    "firebase:setup": "./tools/setup-firebase.sh",
    "firebase:diagnose": "./tools/diagnose-firebase.sh",
    "firebase:test": "./tools/test-firebase.sh",
    "firebase:test-ios": "./tools/test-ios-firebase.sh",
    "firebase:test-android": "./tools/test-android-firebase.sh",
    "firebase:test-mobile": "./tools/test-mobile-firebase.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "sharp": "^0.33.5",
    "turbo": "^2.0.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "dependencies": {}
}
