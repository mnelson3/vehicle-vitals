rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Development: Allow authenticated users to read/write
    match /demo_uploads/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow public reads for demo content
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
