rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public writes to launch signups and suggestions for Coming Soon page
    match /launch_signups/{document} {
      allow create: if request.auth == null && request.resource.data.keys().hasAll(['email', 'timestamp', 'source']);
      allow read: if false; // No public reads for privacy
    }

    match /user_suggestions/{document} {
      allow create: if request.auth == null && request.resource.data.keys().hasAll(['suggestion', 'timestamp', 'source']);
      allow read: if false; // No public reads for privacy
    }

    // Authenticated user data - users can only access their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Temporary rule for development - expires November 12, 2025
    // After this date, only the rules above will apply
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2025, 11, 12);
    }
  }
}
