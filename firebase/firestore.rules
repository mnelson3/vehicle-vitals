rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasExactKeys(requiredKeys) {
      return request.resource.data.keys().hasAll(requiredKeys)
        && request.resource.data.keys().hasOnly(requiredKeys);
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function orgMemberDoc(orgId) {
      return /databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid);
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && exists(orgMemberDoc(orgId))
        && get(orgMemberDoc(orgId)).data.status == 'active';
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId)
        && get(orgMemberDoc(orgId)).data.role in ['org_owner', 'org_admin', 'billing_admin', 'support_agent'];
    }

    // read_only is a real, assignable member role (see setOrganizationMemberRoleCallable) —
    // every other role may write vehicle data, only read_only may not.
    function canWriteOrgVehicles(orgId) {
      return isOrgMember(orgId)
        && get(orgMemberDoc(orgId)).data.role != 'read_only';
    }

    // Matches the role set required to create drafts in
    // createInvoiceDraftCallable/createPayableDraftCallable — without this,
    // billing admins get permission-denied reading the drafts the UI just
    // created via those callables.
    function isOrgBillingAdmin(orgId) {
      return isOrgMember(orgId)
        && get(orgMemberDoc(orgId)).data.role in ['org_owner', 'org_admin', 'billing_admin'];
    }

    // Allow public writes to launch signups and suggestions for Coming Soon page
    match /launch_signups/{document} {
      allow create: if request.auth == null
        && hasExactKeys(['email', 'timestamp', 'source'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.source is string
        && request.resource.data.source.size() > 0
        && request.resource.data.source.size() <= 64
        && request.resource.data.timestamp is timestamp;
      allow read: if false; // No public reads for privacy
    }

    match /user_suggestions/{document} {
      allow create: if request.auth == null
        && hasExactKeys(['suggestion', 'timestamp', 'source'])
        && request.resource.data.suggestion is string
        && request.resource.data.suggestion.size() > 0
        && request.resource.data.suggestion.size() <= 2000
        && request.resource.data.source is string
        && request.resource.data.source.size() > 0
        && request.resource.data.source.size() <= 64
        && request.resource.data.timestamp is timestamp;
      allow read: if false; // No public reads for privacy
    }

    // Authenticated user data - users can only access their own data.
    // quotas/ and subscription/ are carved out of write access below: they
    // are server-computed (AI-analysis usage limits, premium tier/billing
    // state) and must never be directly writable by the client SDK — a
    // modified client could otherwise grant itself unlimited quota or a
    // premium tier by editing its own document. Read access is unaffected
    // so the UI can still display current usage/tier.
    match /users/{userId}/{document=**} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId)
        && !(document.size() > 0 && document[0] in ['quotas', 'subscription']);
    }

    match /users/{userId}/quotas/{month} {
      allow read: if isSelf(userId);
      allow write: if false; // Managed via Cloud Functions
    }

    match /users/{userId}/subscription/{document} {
      allow read: if isSelf(userId);
      allow write: if false; // Managed via Cloud Functions
    }

    // Organization-scoped enterprise model
    match /orgs/{orgId} {
      allow read: if isOrgMember(orgId);
      allow write: if false; // Managed via Cloud Functions

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow write: if false; // Managed via Cloud Functions
      }

      match /vehicles/{vehicleId} {
        allow read: if isOrgMember(orgId);
        allow write: if canWriteOrgVehicles(orgId);

        match /{vehicleDocument=**} {
          allow read: if isOrgMember(orgId);
          allow write: if canWriteOrgVehicles(orgId);
        }
      }

      match /audit/{auditId} {
        allow read: if isOrgAdmin(orgId);
        allow write: if false; // Immutable audit log via Cloud Functions
      }

      match /compliance/{docId} {
        allow read: if isOrgAdmin(orgId);
        allow write: if false; // Managed via Cloud Functions
      }

      match /financeInvoices/{invoiceId} {
        allow read: if isOrgBillingAdmin(orgId);
        allow write: if false; // Managed via Cloud Functions
      }

      match /financePayables/{payableId} {
        allow read: if isOrgBillingAdmin(orgId);
        allow write: if false; // Managed via Cloud Functions
      }
    }

    // Compliance lifecycle requests are server-managed; users can read own requests
    match /complianceRequests/{requestId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Idempotency keys must never be directly writable by clients
    match /idempotencyKeys/{keyId} {
      allow read, write: if false;
    }
  }
}
